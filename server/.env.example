PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_dataplatform
JWT_SECRET=your-super-secret-jwt-key-change-in-production
ENCRYPTION_KEY=your-fernet-32-byte-key
MAX_QUERY_ROWS=1000
SOFT_LIMIT_ROWS=5000
SEMANTIC_CACHE_HIT_THRESHOLD=0.92
SEMANTIC_CACHE_PARTIAL_THRESHOLD=0.80
SEMANTIC_CACHE_TTL_HOURS=24
